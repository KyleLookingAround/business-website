---
import Base from '../layouts/Base.astro';
import { getSettings, getHome, getWork, markHeading, u } from '../lib/site';
import Steps from '../components/Steps.astro';
import Milepost from '../components/Milepost.astro';

const s = await getSettings();
const home = await getHome();
const work = await getWork();
const featured = work.filter((w) => w.data.featured).slice(0, 2);
const teasers = featured.length ? featured : work.slice(0, 2);
---
<Base title={`${s.name} — ${s.strapline}`} description={s.description} nav="home" page="index.html" masthead="hero">

  <!-- HERO — headline on the sky, the viaduct assembling beneath it -->
  <Fragment slot="masthead">
    <p class="milepost"><span class="mp">MP 0</span> {home.hero.eyebrow}</p>
    <h1 set:html={markHeading(home.hero.heading)}></h1>
    <p class="sub">{home.hero.sub}</p>
    <div class="actions">
      <a class="btn btn-primary" href={u('contact.html')}>Start a project</a>
      <a class="btn btn-ghost" href={u('work.html')}>See the work</a>
    </div>
  </Fragment>
  {home.hero.note && <p class="mast-note" slot="masthead-note">{home.hero.note}</p>}

  <!-- MP 1 · RECENT WORK -->
  <section class="section reveal">
    <div class="wrap">
      <div class="section-head">
        <Milepost n={1} label="Recent work" />
        <h2>Two places, one engine — and they couldn't look less alike.</h2>
        <p>A coffee shop and a band, both fast, both self-editable. Have a proper look.</p>
      </div>
      <div class="work-grid">
        {teasers.map((w) => (
          <a class="case" href={u(`work/${w.id}.html`)}>
            <div class="case-shot">
              {w.data.image
                ? <img src={u(w.data.image)} alt={`${w.data.client} website`} loading="lazy" width="800" height="550" />
                : <div class="placeholder">{w.data.client}</div>}
            </div>
            <div class="case-body">
              <p class="case-meta">{w.data.sector} · {w.data.year}</p>
              <h3>{w.data.title}</h3>
              <p>{w.data.summary}</p>
              <p class="more">Read the case study →</p>
            </div>
          </a>
        ))}
      </div>
      <p class="center mt-2"><a class="btn btn-ghost" href={u('work.html')}>Walk the full span</a></p>
    </div>
  </section>

  <div class="colonnade into-alt" aria-hidden="true"></div>

  <!-- MP 2 · WHAT YOU GET -->
  <section class="section alt reveal">
    <div class="wrap">
      <div class="section-head">
        <Milepost n={2} label="What you get" />
      </div>
      <div class="pillars">
        {home.pillars.map((p) => (
          <article class="pillar">
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- MP 3 · HOW IT WORKS -->
  {home.process.length > 0 && (
    <section class="section reveal">
      <div class="wrap">
        <div class="section-head">
          <Milepost n={3} label="How it works" />
          <h2>Three steps, no mystery.</h2>
          <p>From first message to the keys in your hand — here's how a Viaduct site comes together.</p>
        </div>
        <Steps steps={home.process} />
      </div>
    </section>
  )}

  <!-- ARRIVAL · CTA -->
  <section class="section alt reveal">
    <div class="wrap">
      <div class="cta">
        <h2>{home.cta.heading}</h2>
        <p>{home.cta.body}</p>
        <a class="btn btn-primary" href={u('contact.html')}>Get in touch</a>
      </div>
    </div>
  </section>

</Base>
