---
import Base from '../layouts/Base.astro';
import { getSettings, getServices, getFaq, faqJsonLd, u } from '../lib/site';

const s = await getSettings();
const svc = await getServices();
const faq = await getFaq();
---
<Base title={`Services — ${s.name}`} description="Three ways to work with Viaduct Studios — handmade, fast, and yours to edit. Every project quoted individually." nav="services" page="services.html">

  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Services</p>
        <h2>Three spans to choose from.</h2>
        <p>{svc.intro}</p>
      </div>

      <div class="packages">
        {svc.packages.map((p) => (
          <article class="pkg">
            <span class="kind">{p.kind}</span>
            <h3>{p.name}</h3>
            <p class="blurb">{p.blurb}</p>
            <ul>
              {p.includes.map((it) => <li>{it}</li>)}
            </ul>
            <a class="btn btn-ghost btn-block" href={u('contact.html')}>Enquire about {p.name}</a>
          </article>
        ))}
      </div>

      {svc.note && <p class="note">{svc.note}</p>}
    </div>
  </section>

  {faq.length > 0 && (
    <section class="section alt">
      <div class="wrap">
        <div class="section-head">
          <p class="eyebrow">Questions</p>
          <h2>The things people ask.</h2>
        </div>
        <div class="faq">
          {faq.map((item) => (
            <details class="faq-item">
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))}
        </div>
      </div>
      <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd(faq)).replace(/</g, '\\u003c')} />
    </section>
  )}

  <section class="section">
    <div class="wrap">
      <div class="cta">
        <h2>Not sure which one?</h2>
        <p>Tell us about the place. We'll point you at the right span — or tell you honestly if you don't need one yet.</p>
        <a class="btn btn-primary" href={u('contact.html')}>Get in touch</a>
      </div>
    </div>
  </section>

</Base>
