---
import Base from '../layouts/Base.astro';
import { getSettings, getAbout, u } from '../lib/site';
import Milepost from '../components/Milepost.astro';

const s = await getSettings();
const about = await getAbout();
---
<Base title={`About — ${s.name}`} description="Viaduct Studios is one engineer building fast, handmade websites for small businesses around Manchester and Stockport." nav="about" page="about.html">

  <section class="section" style="padding-top:clamp(2rem,5vw,3.2rem)">
    <div class="wrap">
      <Milepost n={1} label="About" />
      <div class="about-layout">
        <div>
          <p class="about-lede">{about.lede}</p>
          <div class="about-body">
            {about.paragraphs.map((p) => <p>{p}</p>)}
          </div>
        </div>

        <aside class="about-aside">
          <div class="about-panel">
            {about.portrait
              ? <img src={u(about.portrait)} alt="Kyle, Viaduct Studios" width="600" height="720" />
              : <div class="about-panel-fill" aria-hidden="true"><span>VS</span></div>}
          </div>
          {about.facts.length > 0 && (
            <ul class="about-facts">
              {about.facts.map((f) => <li>{f}</li>)}
            </ul>
          )}
        </aside>
      </div>

      <div class="values">
        {about.values.map((v) => (
          <div class="value">
            <h3>{v.title}</h3>
            <p>{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="wrap">
      <div class="cta">
        <h2>Built like the viaduct — to carry, and to last.</h2>
        <p>If that's the sort of thing you're after, let's talk.</p>
        <a class="btn btn-primary" href={u('contact.html')}>Start a project</a>
      </div>
    </div>
  </section>

</Base>
